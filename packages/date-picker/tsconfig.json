{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": false,
    "jsx": "react-jsx",
    "lib": [
      "DOM",
      "ES2020",
      "ESNext.Disposable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "strict": true,
    "target": "ES2020",
    "skipLibCheck": true
  },
  "include": [
    "src",
    "tsup.config.ts"
  ]
}
