{
  "name": "aryan-date-picker",
  "version": "0.1.2",
  "description": "A lightweight React date picker component library with Gregorian and Jalali calendar adapters.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/srbadni/aryan-date-picker.git"
  },
  "homepage": "https://github.com/srbadni/aryan-date-picker#readme",
  "bugs": {
    "url": "https://github.com/srbadni/aryan-date-picker/issues"
  },
  "keywords": [
    "react",
    "datepicker",
    "date-picker",
    "calendar",
    "jalali",
    "persian"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
}
