{
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": [
      "DOM",
      "ES2020"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "target": "ES2020",
    "useDefineForClassFields": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "aryan-date-picker": [
        "../../packages/date-picker/src/index.ts"
      ],
      "aryan-date-picker/styles.css": [
        "../../packages/date-picker/src/styles.css"
      ]
    }
  },
  "include": [
    "src",
    "vite.config.ts"
  ]
}
